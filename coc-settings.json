{
  "imselect.defaultInput": "com.apple.keylayout.ABC",
  "imselect.enableStatusItem": false,
  "imselect.enableFloating": false,
  "coc.preferences.colorSupport": false,
  "coc.preferences.formatOnSaveFiletypes": [
    "c",
    "cpp",
    "rust",
    "go",
    "dart",
    "markdown",
    "javascript",
    "typescript",
    "python",
    // "yaml",
    "json"
  ],
  "diagnostic.errorSign": ">",
  "diagnostic.warningSign": "-",
  "diagnostic.checkCurrentLine": true,
  "diagnostic.enableMessage": "always",
  "suggest.timeout": 1000,
  "suggest.noselect": false,
  "suggest.disableMenuShortcut": true,
  "suggest.enablePreselect": true,
  "suggest.maxPreviewWidth": 80,
  "suggest.removeDuplicateItems": true,
  "suggest.minTriggerInputLength": 2,
  "suggest.detailMaxLength": 20,
  "signature.maxWindowWidth": 80,
  "signature.maxWindowHeight": 15,

  "git.addedSign.hlGroup": "GitGutterAdd",
  "git.changedSign.hlGroup": "GitGutterChange",
  "git.removedSign.hlGroup": "GitGutterDelete",
  "git.topRemovedSign.hlGroup": "GitGutterDelete",
  "git.changeRemovedSign.hlGroup": "GitGutterChangeDelete",

  // "suggest.maxCompleteItemCount": 50,
  // "tabnine.priority": 100,
  // "diagnostic.virtualTextPrefix": "▶ ",
  // "codeLens.enable": true,
  // "codeLens.separator": "",
  // "codeLens.subseparator": "|",
  "list.insertMappings": {
    "<C-d>": "feedkeys:\\<C-f>",
    "<C-u>": "feedkeys:\\<C-b>",
    "<C-n>": "normal:j",
    "<C-p>": "normal:k"
  },
  // "typescript.suggest.completeFunctionCalls": true,
  "typescript.preferences.importModuleSpecifier": "non-relative",
  "rust-analyzer.serverPath": "rust-analyzer",
  "rust-analyzer.inlayHints.chainingHints": false,
  "rust-analyzer.completion.postfix.enable": false,
  // "rust-analyzer.lens.enable": true,
  // "rust-analyzer.lens.implementations": false,
  "flutter.lsp.initialization.closingLabels": false,
  "refactor.beforeContext": 2,
  "refactor.afterContext": 2,
  "go.goplsPath": "gopls",
  // "go.goplsArgs": [
  // 	"-remote",
  // 	"auto"
  // ],
  "go.goplsOptions": {
    "completeUnimported": true,
    "usePlaceholders": true,
    "linksInHover": true,
    "gofumpt": true,
    "staticcheck": true,
    "analyses": {
      "ST1000": false,
      "ST1003": false,
      "ST1005": false,
      "ST1021": false
    }
  },
  "python.jediEnabled": false,
  "python.analysis.memory.keepLibraryAst": true,
  "snippets.ultisnips.directories": ["UltiSnips", "gosnippets/UltiSnips"],
  "snippets.snipmate.enable":false,
  "snippets.priority": 99
}
