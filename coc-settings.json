{
	"suggest.maxCompleteItemCount": 10,
	// "suggest.noselect": false,
	// "tabnine.priority": 100,
	"diagnostic.errorSign": ">",
	"diagnostic.warningSign": "-",
	"diagnostic.virtualText": false,
	"diagnostic.virtualTextPrefix": "▶ ",
	"diagnostic.checkCurrentLine": true,
	"diagnostic.enableMessage": "always",
	// "codeLens.enable": true,
	"suggest.minTriggerInputLength": 3,
	"imselect.enableStatusItem": false,
	"list.insertMappings": {
		"<C-d>": "feedkeys:\\<C-f>",
		"<C-u>": "feedkeys:\\<C-b>",
		"<C-n>": "normal:j",
		"<C-p>": "normal:k"
	},
	"typescript.suggest.completeFunctionCalls": true,
	"coc.preferences.colorSupport": false,
	"rust-analyzer.serverPath":"~/.cargo/bin/rust-analyzer",
	"languageserver": {
		// "ccls": {
		//   // "trace.server": "verbose",
		//   "command": "ccls",
		//   "filetypes": ["c", "cpp", "objc", "objcpp"],
		//   "rootPatterns": [".ccls", "compile_commands.json", ".git/"],
		//   "initializationOptions": {
		// 	 "cache": {
		// 	   "directory": "/tmp/ccls"
		// 	 }
		//    }
		// },
		// "ccls-debug": {
		//   "trace.server": "verbose",
		//   "command": "ccls-debug",
		//   "filetypes": ["c", "cpp", "objc", "objcpp"],
		//   "rootPatterns": [".ccls", "compile_commands.json", ".git/"],
		//   "initializationOptions": {
		// 	 "cache": {
		// 	   "directory": "/tmp/ccls"
		// 	 }
		//    }
		// },
		"clangd": {
			// "trace.server": "verbose",
			"command": "clangd",
			"filetypes": [
				"c",
				"cpp",
				"objc",
				"objcpp"
			],
			"rootPatterns": [
				"compile_commands.json",
				".git/"
			]
		},
		"golang": {
			"command": "gopls",
			// "args": ["--diagnostics-style=instant"],
			"rootPatterns": [
				"go.mod",
				".vim/",
				".git/",
				".hg/"
			],
			"filetypes": [
				"go"
			]
		}
	}
}
