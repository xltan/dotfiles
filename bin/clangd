#!/bin/sh
CLANGD=`which -a clangd | sed -n 2p`
CPATH=/Applications/Xcode.app/Contents/Developer/Toolchains/XcodeDefault.xctoolchain/usr/include/c++/v1:`xcrun --show-sdk-path`/usr/include exec $CLANGD --resource-dir=`clang -print-resource-dir` --header-insertion=iwyu --background-index --clang-tidy=0 "$@"
